# Copy this file to `.env` and fill in the values.

# --- Database (Supabase Postgres) ---
# From your Supabase project: Settings → Database → Connection string.
#
# DATABASE_URL = the POOLED connection (Transaction pooler, port 6543).
#   Append ?pgbouncer=true so Prisma disables prepared statements.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
#
# DIRECT_URL = the DIRECT connection (port 5432). Used for migrations / schema push.
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# --- Admin dashboard login ---
ADMIN_EMAIL="admin@edgbastoncollege.co.uk"
ADMIN_PASSWORD="change-me"

# --- Session ---
# A long, random secret used to sign the admin session cookie.
# Generate one with:  openssl rand -base64 32
SESSION_SECRET="please-change-this-to-a-long-random-string"
