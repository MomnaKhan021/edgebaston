# Copy this file to `.env` and fill in the values, then run `npm run db:reset`.

# --- Database ---
# SQLite (default, zero-setup for local/demo):
DATABASE_URL="file:./dev.db"
# For production, switch prisma/schema.prisma `provider` to "postgresql" and use e.g.:
# DATABASE_URL="postgresql://user:password@host:5432/edgebaston?schema=public"

# --- Admin dashboard login ---
ADMIN_EMAIL="admin@edgebaston.edu"
ADMIN_PASSWORD="admin1234"

# --- Session ---
# A long, random secret used to sign the admin session cookie.
# Generate one with:  openssl rand -base64 32
SESSION_SECRET="please-change-this-to-a-long-random-string"
