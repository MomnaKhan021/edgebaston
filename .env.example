# Copy this file to `.env` and fill in the values.

# --- Database (PostgreSQL) ---
# Use a free serverless Postgres such as Neon (https://neon.tech) or
# Vercel Postgres. Paste the connection string here (locally AND in Vercel).
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Admin dashboard login ---
ADMIN_EMAIL="admin@edgebaston.edu"
ADMIN_PASSWORD="admin1234"

# --- Session ---
# A long, random secret used to sign the admin session cookie.
# Generate one with:  openssl rand -base64 32
SESSION_SECRET="please-change-this-to-a-long-random-string"
